# ─────────────────────────────────────────────────────────────────────────────
# HermesWorkspace — Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Prisma) ─────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/hermesworkspace?schema=public"

# ── Slack App credentials ─────────────────────────────────────────────────────
# Found in: api.slack.com/apps → Your App → Basic Information → Signing Secret
SLACK_SIGNING_SECRET="your_slack_signing_secret"

# Found in: api.slack.com/apps → Your App → OAuth & Permissions → Bot Token (xoxb-...)
# Required scopes: chat:write, chat:write.public (to post + update messages)
SLACK_BOT_TOKEN="xoxb-your-bot-token"

# ── Slack Channel IDs ─────────────────────────────────────────────────────────
# Messages are sent via chat.postMessage (not webhooks) so the bot owns them
# and can edit them later via chat.update.
#
# How to get a channel ID:
#   In Slack → right-click channel → View channel details → scroll to bottom of About tab
#   OR: open the channel, look at the URL: slack.com/app_redirect?channel=C0XXXXXXXX

# Sales channel: Demo Request, Partnership, General Inquiry
SLACK_SALES_CHANNEL_ID="C0XXXXXXXXX"

# Support channel: Technical Support, Onboarding, Others
SLACK_SUPPORT_CHANNEL_ID="C0XXXXXXXXX"


PAYLOAD_SECRET=your-random-secret-string
